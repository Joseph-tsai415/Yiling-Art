# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code — local config & state stays local: settings.local.json, agents/, docs/,
# commands/, skills/, plans/, session data. EXCEPTION: .claude/settings.json is TRACKED
# (team-shared agent-team hooks). Git can't re-include a child of a fully-ignored dir, so
# we ignore the CONTENTS (.claude/*) and re-include just settings.json.
# NOTE: CLAUDE.md (project memory) at the repo root is also intentionally TRACKED.
.claude/*
!.claude/settings.json
CLAUDE.local.md

# Node (if added later)
node_modules/
dist/

# Environment
.env
.env.local

# Local-only Google API credentials (injected from GitHub secrets at deploy)
product-card-printer/google-config.local.js
bakery-erp/google-config.local.js

# Design handoff bundles (imported into app folders, the archive itself stays untracked)
*-handoff*.zip

# product-card-printer/assets/: ONLY fonts/ is tracked & deployed (self-hosted
# webfonts the app loads at runtime). Everything else here is local-only — S3-source
# background images, screenshots, and the OAuth client_secret file — never commit.
product-card-printer/assets/*
!product-card-printer/assets/fonts/
